# ==========================================
# Bidora Environment Variables Reference (.env)
# ==========================================

# ==========================================
# 1. Global / Server Configuration
# ==========================================
PORT=5000
NODE_ENV=development

# URL of the frontend client (for CORS and email links)
CLIENT_URL=http://localhost:3000

# ==========================================
# 2. Database Configuration (PostgreSQL)
# ==========================================
# Used by the backend API / Prisma ORM
DATABASE_URL="postgresql://postgres:postgres@localhost:5432/bidora?schema=public"

# ==========================================
# 3. Security & Authentication
# ==========================================
# A long, random string used to sign JWTs (JSON Web Tokens)
JWT_SECRET=super_secret_dev_key_change_in_production
# JWT Expiration time (e.g., 15m, 1h, 7d)
JWT_EXPIRES_IN=7d

# NextAuth / Next.js Secret (for frontend session management)
NEXTAUTH_SECRET=super_secret_nextauth_key
NEXTAUTH_URL=http://localhost:3000

# OAuth Providers (Google)
GOOGLE_CLIENT_ID=your_google_client_id.apps.googleusercontent.com
GOOGLE_CLIENT_SECRET=your_google_client_secret

# ==========================================
# 4. Payments, Escrow, and Wallets
# ==========================================
# Mock Stripe / Razorpay Keys
STRIPE_SECRET_KEY=sk_test_your_mock_stripe_key
STRIPE_WEBHOOK_SECRET=whsec_your_mock_webhook_secret

# Platform Commission Rate (Percentage - e.g. 7 for 7%)
PLATFORM_COMMISSION_PERCENTAGE=7

# ==========================================
# 5. External Services Configuration (Mocks)
# ==========================================
# Email / OTP Provider Credentials (e.g., SendGrid, AWS SES)
EMAIL_SERVICE_API_KEY=your_email_api_key
FROM_EMAIL_ADDRESS=noreply@bidora.local

# Real-time WebSocket Configuration
# For a basic node setup, standard WSS config attached to the HTTP server is sufficient.
# If using a separate service, define URL:
WS_URL=ws://localhost:5000

# Shipping / Logistics Mock API Keys
SHIPPING_API_KEY=mock_shipping_key
